{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git *)",
      "Bash(mkdir -p *)",
      "Bash(openssl rand *)",
      "Bash(curl -s*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uncommitted=$(git status --porcelain 2>/dev/null | head -20); if [ -n \"$uncommitted\" ]; then echo \"UNCOMMITTED CHANGES DETECTED — commit your work before moving on.\"; echo \"$uncommitted\"; fi"
          }
        ]
      }
    ]
  }
}
